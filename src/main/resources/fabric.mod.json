{
  "schemaVersion": 1,
  "id": "retromod",
  "version": "${project.version}",
  "name": "Retromod",
  "description": "Backwards compatibility layer for Minecraft mods - run older mods on newer versions. Works on clients AND servers. Made by the Developers of revivalsmp.net.",
  "authors": ["Bownlux"],
  "contact": {
    "homepage": "https://modrinth.com/mod/retromod",
    "sources": "https://github.com/Bownlux/Retromod",
    "issues": "https://github.com/Bownlux/Retromod/issues"
  },
  "license": "MIT",
  "icon": "assets/retromod/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": ["com.retromod.core.Retromod"],
    "client": ["com.retromod.core.RetromodClient"],
    "server": ["com.retromod.core.RetromodServer"],
    "preLaunch": ["com.retromod.core.RetromodPreLaunch"]
  },
  "depends": {
    "fabricloader": ">=0.16.0",
    "minecraft": ">=1.20",
    "java": ">=17"
  },
  "suggests": {
    "fabric-api": "*"
  },
  "custom": {
    "modmenu": {
      "links": {
        "modmenu.discord": "https://github.com/Bownlux/Retromod",
        "modmenu.issues": "https://github.com/Bownlux/Retromod/issues"
      }
    }
  }
}
