# RetroMod Intermediary → Mojang Official Mappings
# Generated for Minecraft 26.1 (deobfuscated)
#
# This file supplements the built-in mappings in IntermediaryToMojangMapper.java
# with additional less-common class/method/field mappings.
#
# To generate a complete mapping file, use:
#   java -jar retromod.jar mappings generate --intermediary <path> --mojang <path>
#
# Format: TinyV2 (intermediary → official)
#   c	<intermediary>	<official>
#     m	<desc>	<intermediary>	<official>
#     f	<desc>	<intermediary>	<official>

